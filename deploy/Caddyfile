# /etc/caddy/Caddyfile
# Caddy terminates HTTPS (automatic Let's Encrypt) and proxies to uvicorn.
# Requires the api-member DNS record to point directly at this server
# (Cloudflare: DNS-only / grey cloud) so the ACME challenge can reach Caddy.

api-member.earhousesongwritingclub.com {
    reverse_proxy 127.0.0.1:8000

    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        -Server
    }
}
