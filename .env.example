# --- Server ---
API_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./esc.db
SESSION_SECRET=change-me-generate-a-long-random-string

# --- Google OAuth (console.cloud.google.com → Credentials) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Frontends (CORS + post-login redirects) ---
MEMBER_FRONTEND_URL=http://localhost:3001
DASHBOARD_FRONTEND_URL=http://localhost:3002

# Cookie domain. Leave EMPTY for localhost development.
# Production: .earhousesongwritingclub.com
COOKIE_DOMAIN=
# Secure cookies (true in production behind HTTPS)
COOKIE_SECURE=false

# --- Roles ---
# Comma-separated emails that are always superadmin (never stored in DB).
SUPERADMIN_EMAILS=bryanqurniawan@gmail.com

# --- App defaults ---
TIMEZONE=Asia/Jakarta
SESSION_TTL_DAYS=30
